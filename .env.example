# ------------------------------------------------------------------
# Wafa Trust — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NOT be committed or shared.
# ------------------------------------------------------------------

# Razorpay (donation payments) — from the Razorpay dashboard.
# KEY_ID is safe to expose to the browser; SECRET must stay server-side only.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ------------------------------------------------------------------
# ABOUT THE GITHUB TOKEN
# A GitHub personal access token is NOT an app environment variable — the
# website never reads it, so it does not belong in this file (or the zip).
# It is only used for `git push`. On the work laptop, either:
#   - clone over HTTPS and let the OS credential manager store it, or
#   - generate a FRESH token (revoke the earlier one — it was exposed in
#     chat) and paste it when git prompts for a password.
# ------------------------------------------------------------------
